{
  "rewrites": [
    { "source": "/((?!api/|.*\\.).*)", "destination": "/" }
  ],
  "redirects": [
    {
      "source": "/product/:id",
      "destination": "/shop",
      "permanent": true
    },
    {
      "source": "/post/:id",
      "destination": "/blog",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
